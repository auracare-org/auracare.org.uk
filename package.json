		"@tailwindcss/typography": "^0.5.16",
		"@types/d3-geo": "^3.1.0",
		"@types/node": "^22",
		"@types/topojson-client": "^3.1.5",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.3",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^4.1.13",
		"typescript": "^5.0.0",
		"vite": "^7.0.4"
	},
	"dependencies": {
		"@tabler/icons-svelte": "^3.35.0",
